---
import { AppConfig, socialLinks } from '@/utils/AppConfig';

const currentYear = new Date().getFullYear();

interface FooterLink {
  href: string;
  label: string;
  external?: boolean;
}

interface LinkColumn {
  heading: string;
  links: FooterLink[];
}

const columns: LinkColumn[] = [
  {
    heading: 'Pages',
    links: [
      { href: '/', label: 'Home' },
      { href: '/posts/', label: 'Writing' },
      { href: '/rss.xml', label: 'RSS' },
    ],
  },
  {
    heading: 'Social',
    links: socialLinks.map((link) => ({ ...link, external: true })),
  },
];
---

<footer class="mt-20 pb-12">
  <div class="mx-auto max-w-2xl px-6">
    <div class="border-t border-neutral-800/50 pt-10">

      <!-- Top row: tagline + link columns -->
      <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">

        <!-- Brand / tagline -->
        <div class="max-w-xs">
          <a href="/" class="text-sm font-medium text-neutral-300 hover:text-white transition-colors">
            {AppConfig.site_name}
          </a>
          <p class="mt-2 text-xs leading-relaxed text-neutral-600">
            AI Builder &amp; Engineering Manager at Simetrik.<br />
            AWS Community Builder.
          </p>
        </div>

        <!-- Link columns -->
        <div class="flex gap-12">
          {columns.map((col) => (
            <div>
              <h3 class="mb-3 text-xs font-medium uppercase tracking-widest text-neutral-600">
                {col.heading}
              </h3>
              <ul class="flex flex-col gap-2">
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-xs text-neutral-500 hover:text-neutral-300 transition-colors"
                      {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Bottom row: copyright -->
      <div class="mt-10 border-t border-neutral-800/50 pt-6">
        <p class="text-xs text-neutral-700">
          &copy; {currentYear} {AppConfig.authorName}. All rights reserved.
        </p>
      </div>

    </div>
  </div>
</footer>
