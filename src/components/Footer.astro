---
import { AppConfig, socialLinks } from '@/utils/AppConfig';

const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/posts/', label: 'Writing' },
  { href: '/rss.xml', label: 'RSS' },
];

const navLinkClass = 'text-xs text-neutral-600 hover:text-neutral-400 transition-colors';
const socialLinkClass = 'text-xs text-neutral-700 hover:text-neutral-400 transition-colors';
---

<footer class="mt-20 pb-12">
  <div class="mx-auto max-w-2xl px-6">
    <div class="border-t border-neutral-800/50 pt-10">

      <!-- Top row: tagline + nav links -->
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-8">
        <div>
          <p class="text-sm font-medium text-neutral-300">{AppConfig.authorName}</p>
          <p class="text-xs text-neutral-600 mt-1 max-w-xs leading-relaxed">
            AI Builder &amp; Engineering Manager at Simetrik. AWS Community Builder.
          </p>
        </div>

        <nav class="flex flex-col gap-2" aria-label="Footer navigation">
          {navLinks.map((link) => (
            <a href={link.href} class={navLinkClass}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Divider -->
      <div class="border-t border-neutral-800/30 mb-6"></div>

      <!-- Bottom row: copyright + social links -->
      <div class="flex items-center justify-between">
        <p class="text-xs text-neutral-700">
          &copy; {currentYear} {AppConfig.authorName}
        </p>
        <div class="flex items-center gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              class={socialLinkClass}
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</footer>
